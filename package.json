{
  "name": "my-agent",
  "version": "0.1.0",
  "description": "Personal AI Agent for learning purposes — exploring prompt building, workspace management, and agent architecture patterns",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "test:tool:list-cwd": "npx tsx scripts/test-exec-list-cwd.ts",
    "test:tool:background": "npx tsx scripts/test-exec-background.ts",
    "test:tool:yield": "npx tsx scripts/test-exec-yield.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
